---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Terms of Service — SolarROI">
  <header class="border-b border-solar-hairline">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
        <span
          class="inline-block w-3 h-3 rounded-sm bg-solar-orange"
          aria-hidden="true"></span>
        SolarROI
      </a>
      <nav class="flex items-center gap-6 text-sm text-solar-muted">
        <a href="/" class="hover:text-solar-ink">Home</a>
        <a href="/privacy" class="hover:text-solar-ink">Privacy</a>
      </nav>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-24 text-center">
    <p
      class="text-xs font-semibold tracking-[0.18em] uppercase text-solar-orange mb-3"
    >
      Terms of Service
    </p>
    <h1 class="text-4xl font-extrabold tracking-tight">Coming soon</h1>
    <p class="mt-4 text-solar-muted leading-relaxed max-w-xl mx-auto">
      We're finalizing our terms of service ahead of launch. In the meantime,
      see our <a href="/privacy" class="text-solar-orange underline"
        >privacy policy</a
      > or reach us at <a
        href="mailto:support@solarroi.app"
        class="text-solar-orange underline">support@solarroi.app</a
      >.
    </p>
  </main>
</Layout>
